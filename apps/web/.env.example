# ─────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────
# Leave DATABASE_URL unset for zero-setup local dev — Payload falls back to
# a local SQLite file automatically (see src/payload.config.ts).
# DATABASE_URI=file:./payload.db

# For a real client deployment, set DATABASE_URL to a free Neon Postgres
# project's connection string (plan Phase 0.4) — this switches the adapter
# to Postgres automatically:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ─────────────────────────────────────────────────────────────
# CORE
# ─────────────────────────────────────────────────────────────
# Any long random string. Generate one with:  openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# MEDIA (Cloudinary — plan Phase 0.4 / 11)
# ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
